# Watchdog Media — environment variables
# Secrets live in Doppler (project: watchdog-media-website). This file documents
# the shape only. Run the app with:  doppler run -- npm run dev
#
# ---------------------------------------------------------------------------
# Contact form email (provider-agnostic SMTP)
# ---------------------------------------------------------------------------
# If these are unset, the contact form still works — submissions are logged to
# the server console as JSON instead of emailed.
#
# --- ZeptoMail (intended provider) ---
#   MAIL_HOST=smtp.zeptomail.com        # or smtp.zeptomail.eu / smtp.zeptomail.in
#   MAIL_PORT=587
#   MAIL_SECURE=false                   # true for port 465
#   MAIL_USER=emailapikey               # literal string for ZeptoMail
#   MAIL_PASSWORD=                       # ZeptoMail "Send Mail" token
#   MAIL_FROM_NAME=Watchdog Media
#   MAIL_FROM_EMAIL=                     # a verified domain sender in ZeptoMail
#   MAIL_TO=                             # inbox that receives enquiries (defaults to MAIL_FROM_EMAIL)

MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM_NAME=Watchdog Media
MAIL_FROM_EMAIL=
MAIL_TO=
